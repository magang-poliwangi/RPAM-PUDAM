{
  "name": "be",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./src/server.js",
  "scripts": {
    "start": "node ./src/server.js",
    "build": "npm run prisma:generate",
    "dev": "nodemon ./src/server.js",
    "lint": "eslint ./src",
    "lint-fix": "eslint --fix ./src",
    "prisma:generate": "prisma generate --config src/databases/prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config src/databases/prisma.config.ts",
    "prisma:studio": "prisma studio --config src/databases/prisma.config.ts",
    "prisma:seed:dev": "node src/databases/prisma/seed.js",
    "prisma:seed:prod": "node src/databases/prisma/seed.prod.js",
    "prisma:reset": "prisma migrate reset --config src/databases/prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nanoid": "^5.1.16",
    "node-cron": "^4.6.0",
    "nodemon": "^3.1.14",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prisma": "^7.8.0"
  }
}