// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  USER
}


enum StatusValidasi {
  EFEKTIF
  TIDAK_EFEKTIF
  TIDAK_PASTI
}

enum StatusKemajuan {
  BELUM_MULAI
  SEDANG_BERJALAN
  SELESAI
  TERTUNDA
}

enum Prioritas {
  RENDAH
  SEDANG
  TINGGI
}

enum AksiAuditLog {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
}



model User {
  id           String   @id @default(cuid())
  username     String   @unique
  password     String   
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]

  @@map("users")
}


model AuditLog {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  aksi        AksiAuditLog
  namaTabel   String?      
  recordId    String?      
  keterangan  String?      
  createdAt   DateTime     @default(now())

  @@map("audit_logs")
}


model IdentifikasiBahaya {
  id               String   @id @default(cuid())
  kodeLokasi       String
  kodeRisiko       String   @unique
  komponenSpam     String
  kontaminasiX     String
  komponenSpamY    String
  penyebabZ        String
  kejadianBahayaXYZ String
  tipeBahaya       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  penilaianRisiko  PenilaianRisiko[]

  @@map("identifikasi_bahaya")
}


model PenilaianRisiko {
  id                   String              @id @default(cuid())
  identifikasiBahayaId String
  identifikasiBahaya   IdentifikasiBahaya  @relation(fields: [identifikasiBahayaId], references: [id])
  peluang              Int                
  dampak               Int                
  skorRisiko           Int                 
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  kajiUlangRisiko      KajiUlangRisiko[]

  @@map("penilaian_risiko")
}


model KajiUlangRisiko {
  id                  String           @id @default(cuid())
  penilaianRisikoId   String
  penilaianRisiko     PenilaianRisiko  @relation(fields: [penilaianRisikoId], references: [id])
  tindakanPengendalian String
  referensi           String
  validasi            StatusValidasi
  peluangSetelah      Int              
  dampakSetelah       Int              
  skorSetelah         Int              
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  rencanaPerbaikan    RencanaPerbaikan[]

  @@map("kaji_ulang_risiko")
}

model RencanaPerbaikan {
  id                String           @id @default(cuid())
  kajiUlangRisikoId String
  kajiUlangRisiko   KajiUlangRisiko  @relation(fields: [kajiUlangRisikoId], references: [id])
  rencanaPerbaikan  String
  penanggungJawab   String
  jadwal            DateTime
  biaya             Decimal
  sumberPembiayaan  String
  statusKemajuan    StatusKemajuan
  kendala           String?
  prioritas         Prioritas
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  pemantauanOperasional PemantauanOperasional[]

  @@map("rencana_perbaikan")
}


model PemantauanOperasional {
  id                  String            @id @default(cuid())
  rencanaPerbaikanId  String
  rencanaPerbaikan    RencanaPerbaikan  @relation(fields: [rencanaPerbaikanId], references: [id])
  batasKritis         String
  apaYangDipantau     String
  dimana              String
  kapan               String
  bagaimana           String
  pelaksana           String
  analis              String
  penerimaLaporan     String
  tindakanKoreksi     String?
  pelaksanaKoreksi    String?
  waktuKoreksi        DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("pemantauan_operasional")
}